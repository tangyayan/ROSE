
expression ::=
      simple_expression:e1
      {: RESULT = e1; :}

    | simple_expression:e1 EQ simple_expression:e2
      {: if(e1.getType().getTargetType().equals(intType) && e2.getType().getTargetType().equals(intType)) {
             RESULT = new mySymbol.Expression(e1.getCode() + " = " + e2.getCode(), boolType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, e1left, "Type mismatch in '=': expected INTEGER");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | EQ simple_expression:e1
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1left, "Missing left operand for '='");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    | simple_expression:e1 EQ
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1right, "Missing right operand for '='");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}

    | simple_expression:e1 NEQ simple_expression:e2
      {: if(e1.getType().getTargetType().equals(intType) && e2.getType().getTargetType().equals(intType)) {
             RESULT = new mySymbol.Expression(e1.getCode() + " != " + e2.getCode(), boolType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, e1left, "Type mismatch in '#': expected INTEGER");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | NEQ simple_expression:e1
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1left, "Missing left operand for '#'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    | simple_expression:e1 NEQ
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1right, "Missing right operand for '#'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}

    | simple_expression:e1 LT simple_expression:e2
      {: if(e1.getType().getTargetType().equals(intType) && e2.getType().getTargetType().equals(intType)) {
             RESULT = new mySymbol.Expression(e1.getCode() + " < " + e2.getCode(), boolType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, e1left, "Type mismatch in '<': expected INTEGER");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | LT simple_expression:e1
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1left, "Missing left operand for '<'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    | simple_expression:e1 LT
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1right, "Missing right operand for '<'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}

    | simple_expression:e1 LEQ simple_expression:e2
      {: if(e1.getType().getTargetType().equals(intType) && e2.getType().getTargetType().equals(intType)) {
             RESULT = new mySymbol.Expression(e1.getCode() + " <= " + e2.getCode(), boolType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, e1left, "Type mismatch in '<=': expected INTEGER");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | LEQ simple_expression:e1
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1left, "Missing left operand for '<='");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    | simple_expression:e1 LEQ
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1right, "Missing right operand for '<='");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}

    | simple_expression:e1 GT simple_expression:e2
      {: if(e1.getType().getTargetType().equals(intType) && e2.getType().getTargetType().equals(intType)) {
             RESULT = new mySymbol.Expression(e1.getCode() + " > " + e2.getCode(), boolType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, e1left, "Type mismatch in '>': expected INTEGER");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | GT simple_expression:e1
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1left, "Missing left operand for '>'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    | simple_expression:e1 GT
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1right, "Missing right operand for '>'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}

    | simple_expression:e1 GEQ simple_expression:e2
      {: if(e1.getType().getTargetType().equals(intType) && e2.getType().getTargetType().equals(intType)) {
             RESULT = new mySymbol.Expression(e1.getCode() + " >= " + e2.getCode(), boolType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, e1left, "Type mismatch in '>=': expected INTEGER");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | GEQ simple_expression:e1
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1left, "Missing left operand for '>='");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    | simple_expression:e1 GEQ
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1right, "Missing right operand for '>='");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    ;

simple_expression ::=
      term:t {: RESULT = t; :}

    | PLUS term:t
      {: if(t.getType().getTargetType().equals(intType)) {
             RESULT = new mySymbol.Expression("+" + t.getCode(), intType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, tleft, "Unary '+' requires INTEGER operand");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | MINUS term:t
      {: if(t.getType().getTargetType().equals(intType)) {
             RESULT = new mySymbol.Expression("-" + t.getCode(), intType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, tleft, "Unary '-' requires INTEGER operand");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}

    | simple_expression:e1 PLUS term:e2
      {: if(e1.getType().getTargetType().equals(intType) && e2.getType().getTargetType().equals(intType)) {
             RESULT = new mySymbol.Expression(e1.getCode() + " + " + e2.getCode(), intType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, e1left, "Type mismatch in '+': expected INTEGER");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | simple_expression:e1 PLUS
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1right, "Missing right operand for '+'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}

    | simple_expression:e1 MINUS term:e2
      {: if(e1.getType().getTargetType().equals(intType) && e2.getType().getTargetType().equals(intType)) {
             RESULT = new mySymbol.Expression(e1.getCode() + " - " + e2.getCode(), intType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, e1left, "Type mismatch in '-': expected INTEGER");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | simple_expression:e1 MINUS
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1right, "Missing right operand for '-'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}

    | simple_expression:e1 OR term:e2
      {: if(e1.getType().getTargetType().equals(boolType) && e2.getType().getTargetType().equals(boolType)) {
             RESULT = new mySymbol.Expression(e1.getCode() + " OR " + e2.getCode(), boolType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, e1left, "Type mismatch in 'OR': expected BOOLEAN");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | simple_expression:e1 OR
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1right, "Missing right operand for 'OR'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    | OR term:t
      {: ErrorReport.reportError(ErrorType.MissingOperandException, tleft, "Missing left operand for 'OR'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    ;

term ::=
      factor:f {: RESULT = f; :}

    | term:e1 TIMES factor:e2
      {: if(e1.getType().getTargetType().equals(intType) && e2.getType().getTargetType().equals(intType)) {
             RESULT = new mySymbol.Expression(e1.getCode() + " * " + e2.getCode(), intType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, e1left, "Type mismatch in '*': expected INTEGER");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | term:e1 TIMES
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1right, "Missing right operand for '*'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    | TIMES factor:f
      {: ErrorReport.reportError(ErrorType.MissingOperandException, fleft, "Missing left operand for '*'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}

    | term:e1 DIV factor:e2
      {: if(e1.getType().getTargetType().equals(intType) && e2.getType().getTargetType().equals(intType)) {
             RESULT = new mySymbol.Expression(e1.getCode() + " / " + e2.getCode(), intType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, e1left, "Type mismatch in 'DIV': expected INTEGER");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | term:e1 DIV
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1right, "Missing right operand for 'DIV'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    | DIV factor:f
      {: ErrorReport.reportError(ErrorType.MissingOperandException, fleft, "Missing left operand for 'DIV'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}

    | term:e1 MOD factor:e2
      {: if(e1.getType().getTargetType().equals(intType) && e2.getType().getTargetType().equals(intType)) {
             RESULT = new mySymbol.Expression(e1.getCode() + " % " + e2.getCode(), intType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, e1left, "Type mismatch in 'MOD': expected INTEGER");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | term:e1 MOD
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1right, "Missing right operand for 'MOD'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    | MOD factor:f
      {: ErrorReport.reportError(ErrorType.MissingOperandException, fleft, "Missing left operand for 'MOD'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}

    | term:e1 AND factor:e2
      {: if(e1.getType().getTargetType().equals(boolType) && e2.getType().getTargetType().equals(boolType)) {
             RESULT = new mySymbol.Expression(e1.getCode() + " AND " + e2.getCode(), boolType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, e1left, "Type mismatch in 'AND': expected BOOLEAN");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
    | term:e1 AND
      {: ErrorReport.reportError(ErrorType.MissingOperandException, e1right, "Missing right operand for 'AND'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    | AND factor:f
      {: ErrorReport.reportError(ErrorType.MissingOperandException, fleft, "Missing left operand for 'AND'");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
	| term:t1 factor:f2
      {: ErrorReport.reportError(ErrorType.MissingOperatorException, t1right, "Missing operator between two factors");
         RESULT = new mySymbol.Expression(t1.getCode(), t1.getType());
      :}
    ;


factor ::=
      INTEGER:i
      {: RESULT = new mySymbol.Expression(i.toString(), intType); :}

    | LPAREN expression:e RPAREN {: RESULT = e; :}
    | LPAREN:l RPAREN
      {: ErrorReport.reportError(ErrorType.MissingOperandException, lleft, "Empty parentheses");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}
    | error RPAREN:r
      {: ErrorReport.reportError(ErrorType.MissingLeftParenthesisException, rleft, "Missing left parenthesis");
         RESULT = new mySymbol.Expression("ERROR", errorType);
      :}

    | NOT factor:f
      {: if(f.getType().getTargetType().equals(boolType)) {
             RESULT = new mySymbol.Expression("NOT " + f.getCode(), boolType);
         } else {
             ErrorReport.reportError(ErrorType.TypeMismatchedException, fleft, "Type mismatch in 'NOT': expected BOOLEAN");
             RESULT = new mySymbol.Expression("ERROR", errorType);
         }
      :}
	| identifier_selector:is {: RESULT = is; :}
    ;